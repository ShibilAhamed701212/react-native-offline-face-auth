{
  "expo": {
    "name": "NHAI Face Attendance",
    "description": "NHAI Offline Facial Recognition & Liveness Attendance System. Fully offline face enrollment, anti-spoofing liveness detection, GPS attendance tracking, and smart sync.",
    "slug": "nhai-facial-attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "face-recognition",
    "githubUrl": "https://github.com/maateusx/react-native-facial-recognition",
    "primaryColor": "#318ede",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "splash": {
      "image": "./src/assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#318ede"
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "requireFullScreen": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "$(PRODUCT_NAME) needs access to your camera for facial recognition features.",
        "NSFaceIDUsageDescription": "Enable Face ID for enhanced security when accessing the app.",
        "UIRequiredDeviceCapabilities": [
          "front-facing-camera"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.maateusx.facerecognition"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/splash-icon.png",
        "backgroundColor": "#318ede"
      },
      "allowBackup": false,
      "minSdkVersion": 26,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "package": "com.maateusx.facerecognition"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "$(PRODUCT_NAME) needs access to your camera for facial recognition features.",
          "enableMicrophonePermission": false
        }
      ],
      [
        "onnxruntime-react-native",
        {
          "bundleCustomONNXModel": true
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "$(PRODUCT_NAME) needs access to your location for attendance tracking.",
          "locationWhenInUsePermission": "$(PRODUCT_NAME) needs access to your location for attendance tracking."
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Enable Face ID to secure your biometric data."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "9f43938f-a8d5-453e-bd28-643bcf45c6f7"
      }
    },
    "owner": "shibilahamed"
  }
}
